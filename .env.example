# Local development (SQLite file)
DATABASE_URL="file:./dev.db"

# Probe endpoint shared secret. Required.
PROBE_SECRET="generate-a-long-random-string"

# Bearer token for /api/tickets (agent ↔ pulsewatch).
# Generate: `node -e "console.log('tk_' + require('node:crypto').randomBytes(24).toString('hex'))"`
TICKETS_API_TOKEN="generate-a-long-random-string"

# Optional: enables in-app "Delegate to Claude" + Approve & deploy.
# Personal access token with scope=repo on this repo.
GITHUB_TOKEN=""
GITHUB_REPO="sabootergmail/pulsewatch"

# Optional: enables Discord alerts on incident/release/rollback events.
# Get one from a Discord server → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=""

# Production (Vercel) — swap to Turso for persistence (see DR.md):
# TURSO_DATABASE_URL="libsql://pulsewatch-xxxxx.turso.io"
# TURSO_AUTH_TOKEN="from `turso db tokens create pulsewatch`"

# Log level (pino). Defaults: debug in dev, info in prod.
# LOG_LEVEL="debug"
