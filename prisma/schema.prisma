// PulseWatch — uptime monitoring & incident management
// SQLite for MVP. Swap provider + DATABASE_URL for Postgres in prod.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Monitor {
  id              String     @id @default(cuid())
  name            String
  url             String
  method          String     @default("GET")
  expectedStatus  Int        @default(200)
  intervalSeconds Int        @default(60)
  timeoutMs       Int        @default(5000)
  status          String     @default("unknown") // unknown | up | down | paused
  paused          Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  lastCheckedAt   DateTime?

  checks    Check[]
  incidents Incident[]

  @@index([status])
}

model Check {
  id          String   @id @default(cuid())
  monitorId   String
  monitor     Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status      String   // up | down
  httpStatus  Int?
  latencyMs   Int?
  error       String?
  checkedAt   DateTime @default(now())

  @@index([monitorId, checkedAt])
}

model Incident {
  id          String    @id @default(cuid())
  monitorId   String
  monitor     Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status      String    @default("open") // open | resolved
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
  cause       String?
  summary     String?

  @@index([monitorId, status])
}

model Task {
  id              String    @id @default(cuid())
  title           String
  description     String?
  type            String    @default("task")    // task | release_approval | rollback
  status          String    @default("backlog") // backlog | in_progress | ready_for_release | approved | done | rolled_back
  priority        String    @default("medium")  // low | medium | high
  assignedTo      String?   // null | "agent:claude" | name
  githubIssueUrl  String?
  githubPrUrl     String?
  githubPrNumber  Int?
  previewUrl      String?
  summary         String?   // agent-written release notes for release_approval
  relatedTaskId   String?   // release_approval links back to the originating task
  approvedBy      String?
  approvedAt      DateTime?
  rolledBackAt    DateTime?
  rollbackReason  String?
  rollbackLevel    String?  // L1 (code) | L2 (code+db PITR) | L3 (git revert)
  rollbackTargetId String? // Release.id we're rolling back TO
  rollbackScope    String? // "code" | "code+db" | "full"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([relatedTaskId])
}

model Release {
  id              String    @id @default(cuid())
  version         String    // "0.2.0" (semver from package.json at release time)
  gitSha          String
  deployedAt      DateTime  @default(now())
  status          String    @default("live")  // live | previous | rolled_back
  vercelDeployUrl String
  sourceTaskId    String?   // originating release_approval task
  smokeTestStatus String?   // passed | failed | pending

  @@index([deployedAt])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String   @default("system")
  action     String   // monitor.* | incident.* | probe.run | task.create | task.update | task.delete | task.delegate | task.complete
  entityType String?  // Monitor | Incident | Check
  entityId   String?
  metadata   String?  // JSON-encoded payload
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}
